DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# URL pública del panel de osTicket (staff), sin barra final. Se usa para
# armar el link "Ver en osTicket" de cada ticket: {OSTICKET_BASE_URL}/scp/tickets.php?id=<ticket_id>
# Si se deja vacía, los tickets se muestran igual pero sin ese link.
OSTICKET_BASE_URL=https://soporte.gcslatam.com/osticket

# Firma las cookies de sesión de TODOS los usuarios (login general, no solo
# admin). Es el único secreto real de esta sección — los usuarios en sí
# (username/passwordHash/role) viven en src/data/users.json, no acá.
JWT_SECRET=

# Bootstrap del primer usuario admin: src/data/users.seed.json (trackeado en
# git) se copia a src/data/users.json (gitignored) la primera vez que el
# proceso arranca y ese archivo todavía no existe. Para generar el hash de
# la contraseña del admin inicial:
#   npm run hash-password -- "tu-contraseña"
# Después de ese primer arranque, usuarios/roles se administran desde el
# panel /admin/sites (sección "Usuarios") — ya no hace falta tocar el seed.

# Envío del correo de "¿Olvidaste tu contraseña?" (nodemailer, transporte
# Gmail). GMAIL_APP_PASSWORD es una contraseña de aplicación de Gmail (no la
# contraseña real de la cuenta) — se genera en la configuración de seguridad
# de la cuenta de Google. NUNCA subir el valor real de esta variable a git.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Base para armar el link del correo de recuperación:
# {FRONTEND_BASE_URL}/reset-password?token=... — sin barra final. En local
# usar http://localhost:5173 para que el link del correo apunte al frontend
# de desarrollo en vez del dominio real de producción.
FRONTEND_BASE_URL=https://mapaincidencias.gcslatam.com
